# ===========================================
# 依赖
# ===========================================
node_modules/
bower_components/

# ===========================================
# 构建产物
# ===========================================
dist/
build/
out/
*.min.js
*.bundle.js

# ===========================================
# 开发工具
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db

# ===========================================
# 日志文件
# ===========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===========================================
# 运行时数据
# ===========================================
*.pid
*.seed
*.pid.lock

# ===========================================
# 测试覆盖率
# ===========================================
coverage/
.nyc_output/

# ===========================================
# 环境变量
# ===========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===========================================
# 临时文件
# ===========================================
*.tmp
*.temp
.cache/
.parcel-cache/

# ===========================================
# Git 相关
# ===========================================
# 除非您正在使用 SaaS
# 但这会阻止硬链接，因为它通常用于 Windows 上的 Docker
# .dockerignore

# COMMIT_EDITMSG
# 注意：如果您有 .git/ 目录中的任何内容，请勿提交
.git/
# .gitignore 中不需要这一行，因为 .git 本身就是版本库的一部分
# 如果您的 .gitignore 中有它，请将其删除
!.gitkeep

# ===========================================
# 模拟和存根
# ===========================================
__mocks__/
__stubs__/

# ===========================================
# IDE 特定文件
# ===========================================
*.sublime-*

# ===========================================
# 其他
# ===========================================
*.bak
*.backup
*.old
*.orig
*.orig.*
*.md.html
*.orig.*

# ===========================================
# 备注
# ===========================================
# 这个项目是一个单文件应用（index.html）
# 所有的代码都在 index.html 中
# 不需要 .gitignore 中的任何特殊规则
# index.html 已经通过 .gitignore 规则正确处理